generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ──

enum Role {
  CUSTOMER
  ADMIN
}

enum ServiceType {
  ALTERATION
  READY_MADE
}

enum FitPreference {
  SLIM
  REGULAR
  RELAXED
  WIDE
}

enum FulfillmentType {
  PICKUP
  DELIVERY
}

enum OrderStatus {
  PENDING_PAYMENT
  PAYMENT_VERIFIED
  PROCESSING
  READY_FOR_PICKUP
  OUT_FOR_DELIVERY
  COMPLETED
  CANCELLED
}

// ── Models ──

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  phone     String?
  role      Role     @default(CUSTOMER)
  orders    Order[]
  cart      Cart?
  notifications Notification[]
  reviews   Review[]
  backInStockSubscriptions BackInStockSubscription[]
  createdAt DateTime @default(now())
}

model GarmentType {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  slug      String   @unique
  deletedAt DateTime?
  orders    Order[]
}

model Category {
  id           Int       @id @default(autoincrement())
  name         String    @unique
  slug         String    @unique
  sizeGuideUrl String?
  deletedAt    DateTime?
  products     Product[]
}

model Product {
  id          Int              @id @default(autoincrement())
  name        String
  description String?
  category    Category         @relation(fields: [categoryId], references: [id])
  categoryId  Int
  color       String?
  size        String?
  price       Decimal          @db.Decimal(10, 2)
  stock       Int              @default(0)
  imageUrl    String?
  images      ProductImage[]
  variants    ProductVariant[]
  orderItems  OrderItem[]
  cartItems   CartItem[]
  stockLogs   StockLog[]
  reviews     Review[]
  backInStockSubscriptions BackInStockSubscription[]
  deletedAt   DateTime?
}

model ProductVariant {
  id        Int      @id @default(autoincrement())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId Int
  size      String?
  color     String?
  price     Decimal? @db.Decimal(10, 2)
  stock     Int      @default(0)
  imageUrl  String?
  sku       String?
  cartItems CartItem[]
  orderItems OrderItem[]
  stockLogs StockLog[]
  @@unique([productId, size, color])
}

model ProductImage {
  id        Int      @id @default(autoincrement())
  product   Product  @relation(fields: [productId], references: [id])
  productId Int
  url       String
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model StockLog {
  id        Int             @id @default(autoincrement())
  product   Product         @relation(fields: [productId], references: [id])
  productId Int
  variant   ProductVariant? @relation(fields: [variantId], references: [id])
  variantId Int?
  change    Int
  note      String?
  createdAt DateTime        @default(now())
}

model Order {
  id              String          @id @default(cuid())
  orderNumber     String          @unique @default(cuid())
  user            User            @relation(fields: [userId], references: [id])
  userId          String
  serviceType     ServiceType

  // Alteration-specific
  garmentType     GarmentType?    @relation(fields: [garmentTypeId], references: [id])
  garmentTypeId   Int?
  garmentPhotoUrl String?
  measurements    Measurement?
  fitPreference   FitPreference?
  pickupDate      DateTime?

  // Ready-made-specific
  items           OrderItem[]
  fulfillment     FulfillmentType?
  deliveryAddress String?

  // Shared
  serviceFee          Decimal?        @db.Decimal(10, 2)
  totalAmount         Decimal         @db.Decimal(10, 2)
  paymentMethod       String?
  paymentRef          String?
  status              OrderStatus     @default(PENDING_PAYMENT)
  statusHistory       StatusHistory[]
  notifications       Notification[]

  estimatedCompletion DateTime?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  deletedAt           DateTime?
}

model Measurement {
  id            String   @id @default(cuid())
  order         Order    @relation(fields: [orderId], references: [id])
  orderId       String   @unique

  waist         Float?
  hip           Float?
  thighWidth    Float?
  inseam        Float?
  length        Float?
  legOpening    Float?
  shoulder      Float?
  chest         Float?
  sleeveLength  Float?
  shirtLength   Float?
  pantsWaist    Float?
  pantsLength   Float?
}

model OrderItem {
  id        String          @id @default(cuid())
  order     Order           @relation(fields: [orderId], references: [id])
  orderId   String
  product   Product         @relation(fields: [productId], references: [id])
  productId Int
  variant   ProductVariant? @relation(fields: [variantId], references: [id])
  variantId Int?
  quantity  Int
  price     Decimal         @db.Decimal(10, 2)
}

model StatusHistory {
  id        String      @id @default(cuid())
  order     Order       @relation(fields: [orderId], references: [id])
  orderId   String
  status    OrderStatus
  note      String?
  changedBy String?
  createdAt DateTime @default(now())
}

model ShopSetting {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String
}

model Cart {
  id        String     @id @default(cuid())
  user      User       @relation(fields: [userId], references: [id])
  userId    String     @unique
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model CartItem {
  id        String          @id @default(cuid())
  cart      Cart            @relation(fields: [cartId], references: [id])
  cartId    String
  product   Product         @relation(fields: [productId], references: [id])
  productId Int
  variant   ProductVariant? @relation(fields: [variantId], references: [id])
  variantId Int?
  quantity  Int
  color     String?
  size      String?
  createdAt DateTime        @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  order     Order?   @relation(fields: [orderId], references: [id])
  orderId   String?
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model ShopSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

model Review {
  id        Int      @id @default(autoincrement())
  product   Product  @relation(fields: [productId], references: [id])
  productId Int
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  @@unique([productId, userId])
}

model BackInStockSubscription {
  id        Int      @id @default(autoincrement())
  product   Product  @relation(fields: [productId], references: [id])
  productId Int
  user      User?    @relation(fields: [userId], references: [id])
  userId    String?
  email     String
  notified  Boolean  @default(false)
  createdAt DateTime @default(now())
}
